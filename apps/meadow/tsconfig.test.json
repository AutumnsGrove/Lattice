{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "bundler",
		"allowJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"strict": true,
		"types": ["@cloudflare/workers-types"],
		"paths": {
			"$lib/*": ["./src/lib/*"]
		}
	},
	"include": ["src/**/*.test.ts", "src/lib/**/*.ts", "src/test-stubs/**/*.ts"]
}
