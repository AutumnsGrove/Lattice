#!/bin/bash
# Pre-commit hook - JavaScript/TypeScript code quality checks
# Runs Prettier formatting and ESLint linting on staged JS/TS files

set -e

# Ensure /dev/fd exists — required for bash process substitution (< <(...)).
# Some container environments (Docker, CI runners) omit this symlink.
if [ ! -e /dev/fd ]; then
    ln -sf /proc/self/fd /dev/fd 2>/dev/null || true
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Detect if Bun is available (prefer for speed)
USE_BUN=false
if command -v bun &> /dev/null; then
    USE_BUN=true
fi

# Get staged JavaScript/TypeScript files
js_ts_files=$(git diff --cached --name-only --diff-filter=ACM | grep '\.\(js\|jsx\|ts\|tsx\|mjs\|cjs\)$' || true)

# Skip if no JS/TS files are staged
if [ -z "$js_ts_files" ]; then
    echo -e "${GREEN}✓ No JavaScript/TypeScript files to check${NC}"
    exit 0
fi

echo -e "${YELLOW}Checking staged JavaScript/TypeScript files:${NC}"
echo "$js_ts_files"
echo ""

# Track if any checks fail
checks_failed=0

# ============================================================================
# PRETTIER FORMATTER CHECK
# ============================================================================
if [ "$USE_BUN" = true ]; then
    echo -e "${YELLOW}Running Prettier formatter check ${BLUE}(bun)${YELLOW}...${NC}"
else
    echo -e "${YELLOW}Running Prettier formatter check...${NC}"
fi

if [ "$USE_BUN" = true ] && [ -f "node_modules/.bin/prettier" ]; then
    # Bun (fastest)
    if bun x prettier --check $js_ts_files 2>&1; then
        echo -e "${GREEN}✓ Prettier formatting passed${NC}"
    else
        echo -e "${RED}✗ Prettier formatting failed${NC}"
        echo -e "${YELLOW}Files need formatting:${NC}"
        bun x prettier --list-different $js_ts_files 2>&1 || true
        echo ""
        echo -e "${YELLOW}To fix: run 'bun x prettier --write .'${NC}"
        checks_failed=1
    fi
elif command -v prettier &> /dev/null; then
    # Global Prettier
    if prettier --check $js_ts_files 2>&1; then
        echo -e "${GREEN}✓ Prettier formatting passed${NC}"
    else
        echo -e "${RED}✗ Prettier formatting failed${NC}"
        echo -e "${YELLOW}Files need formatting:${NC}"
        prettier --list-different $js_ts_files 2>&1 || true
        echo ""
        echo -e "${YELLOW}To fix: run 'prettier --write .' or 'prettier --write <filename>'${NC}"
        checks_failed=1
    fi
elif [ -f "node_modules/.bin/prettier" ]; then
    # Local Prettier via npm
    if npx prettier --check $js_ts_files 2>&1; then
        echo -e "${GREEN}✓ Prettier formatting passed${NC}"
    else
        echo -e "${RED}✗ Prettier formatting failed${NC}"
        echo -e "${YELLOW}Files need formatting:${NC}"
        npx prettier --list-different $js_ts_files 2>&1 || true
        echo ""
        echo -e "${YELLOW}To fix: run 'npx prettier --write .'${NC}"
        checks_failed=1
    fi
else
    echo -e "${RED}✗ Prettier is not installed${NC}"
    echo -e "${YELLOW}Install with: npm install -D prettier${NC}"
    echo -e "${YELLOW}Or globally: npm install -g prettier${NC}"
    exit 1
fi

echo ""

# ============================================================================
# ESLINT CHECK (only if config exists)
# ============================================================================

# Check for any ESLint config file in the repo root
has_eslint_config=false
for config in eslint.config.js eslint.config.mjs eslint.config.cjs .eslintrc .eslintrc.js .eslintrc.json .eslintrc.yml; do
    if [ -f "$config" ]; then
        has_eslint_config=true
        break
    fi
done

if [ "$has_eslint_config" = true ]; then
    if [ "$USE_BUN" = true ]; then
        echo -e "${YELLOW}Running ESLint check ${BLUE}(bun)${YELLOW}...${NC}"
    else
        echo -e "${YELLOW}Running ESLint check...${NC}"
    fi

    if [ "$USE_BUN" = true ] && [ -f "node_modules/.bin/eslint" ]; then
        # Bun (fastest)
        if bun x eslint $js_ts_files 2>&1; then
            echo -e "${GREEN}✓ ESLint passed${NC}"
        else
            echo -e "${RED}✗ ESLint failed${NC}"
            echo -e "${YELLOW}Linting violations found:${NC}"
            bun x eslint $js_ts_files
            echo ""
            echo -e "${YELLOW}To fix: run 'bun x eslint --fix .'${NC}"
            checks_failed=1
        fi
    elif command -v eslint &> /dev/null; then
        if eslint $js_ts_files 2>&1; then
            echo -e "${GREEN}✓ ESLint passed${NC}"
        else
            echo -e "${RED}✗ ESLint failed${NC}"
            echo -e "${YELLOW}Linting violations found:${NC}"
            eslint $js_ts_files
            echo ""
            echo -e "${YELLOW}To fix: run 'eslint --fix .' or fix violations manually${NC}"
            checks_failed=1
        fi
    elif [ -f "node_modules/.bin/eslint" ]; then
        if npx eslint $js_ts_files 2>&1; then
            echo -e "${GREEN}✓ ESLint passed${NC}"
        else
            echo -e "${RED}✗ ESLint failed${NC}"
            echo -e "${YELLOW}Linting violations found:${NC}"
            npx eslint $js_ts_files
            echo ""
            echo -e "${YELLOW}To fix: run 'npx eslint --fix .'${NC}"
            checks_failed=1
        fi
    else
        echo -e "${YELLOW}⚠ ESLint is not installed (optional but recommended)${NC}"
    fi
else
    echo -e "${GREEN}✓ ESLint skipped (no config found)${NC}"
fi

echo ""

# ============================================================================
# TYPESCRIPT TYPE CHECK (if TypeScript files present)
# ============================================================================
ts_files=$(echo "$js_ts_files" | grep '\.\(ts\|tsx\)$' || true)
if [ -n "$ts_files" ]; then
    if [ -f "tsconfig.json" ]; then
        if [ "$USE_BUN" = true ]; then
            echo -e "${YELLOW}Running TypeScript type check ${BLUE}(bun)${YELLOW}...${NC}"
        else
            echo -e "${YELLOW}Running TypeScript type check...${NC}"
        fi

        if [ "$USE_BUN" = true ] && [ -f "node_modules/.bin/tsc" ]; then
            # Bun (fastest)
            if bun x tsc --noEmit 2>&1; then
                echo -e "${GREEN}✓ TypeScript type check passed${NC}"
            else
                echo -e "${RED}✗ TypeScript type check failed${NC}"
                checks_failed=1
            fi
        elif command -v tsc &> /dev/null; then
            if tsc --noEmit 2>&1; then
                echo -e "${GREEN}✓ TypeScript type check passed${NC}"
            else
                echo -e "${RED}✗ TypeScript type check failed${NC}"
                checks_failed=1
            fi
        elif [ -f "node_modules/.bin/tsc" ]; then
            if npx tsc --noEmit 2>&1; then
                echo -e "${GREEN}✓ TypeScript type check passed${NC}"
            else
                echo -e "${RED}✗ TypeScript type check failed${NC}"
                checks_failed=1
            fi
        fi
        echo ""
    fi
fi

# ============================================================================
# BARE FETCH() CHECK (CSRF protection)
# ============================================================================
# Client-side code must use api.*() from $lib/utils/api for state-mutating
# requests. Bare fetch() skips CSRF token injection and credentials.
# The server has an origin-based fallback, but api.*() is the correct pattern.
#
# What's caught: Any bare fetch() with a string/template URL argument
# What's exempt: SvelteKit form actions (fetch("?/...)), imports, type defs
# How to suppress: Add "// csrf-ok" on the same line or the next line
#
# Server-side files (+server.ts, +page.server.ts, +layout.server.ts) are
# excluded since they legitimately call external APIs.

# Get ALL staged client-side files (svelte + non-server ts/js)
all_staged=$(git diff --cached --name-only --diff-filter=ACM | grep '\.\(svelte\|ts\|tsx\|js\|jsx\)$' || true)

if [ -n "$all_staged" ]; then
    # Filter to client-side only (exclude server files, test files, and config)
    client_files=""
    for f in $all_staged; do
        case "$f" in
            *+server.ts|*+page.server.ts|*+layout.server.ts|*.test.ts|*.test.js|*.spec.ts|*.spec.js|*hooks.server.ts|*hooks.client.ts)
                # Skip server-side, test, and hook files
                ;;
            *)
                client_files="$client_files $f"
                ;;
        esac
    done

    if [ -n "$client_files" ]; then
        # Look for bare fetch() calls with URL arguments
        # Matches: fetch("/..., fetch('/..., fetch(`/..., fetch(url, fetch(endpoint
        # Excludes: fetch("?/... (SvelteKit form actions — handled by SvelteKit CSRF)
        bare_fetch_hits=""
        for f in $client_files; do
            while IFS=: read -r line_num line_content; do
                # Check if the matched line itself contains csrf-ok
                if echo "$line_content" | grep -q 'csrf-ok'; then
                    continue
                fi
                # Check the next line (Prettier moves inline comments down)
                next_line=$(sed -n "$((line_num + 1))p" "$f" 2>/dev/null)
                if echo "$next_line" | grep -q 'csrf-ok'; then
                    continue
                fi
                # Skip SvelteKit form actions: fetch("?/actionName"
                if echo "$line_content" | grep -qE 'fetch\s*\(\s*[\"'"'"'`]\s*\?/'; then
                    continue
                fi
                bare_fetch_hits="${bare_fetch_hits}${f}:${line_num}: ${line_content}
"
            done < <(grep -n 'fetch\s*(\s*[\"'"'"'`]\s*/' "$f" 2>/dev/null || true)
        done
        # Trim trailing newline
        bare_fetch_hits=$(echo "$bare_fetch_hits" | sed '/^$/d')

        if [ -n "$bare_fetch_hits" ]; then
            echo -e "${RED}✗ Bare fetch() detected in client code${NC}"
            echo -e "${YELLOW}Client-side fetch() should use api.*() from \$lib/utils/api${NC}"
            echo -e "${YELLOW}for CSRF token injection and credentials:${NC}"
            echo ""
            echo "$bare_fetch_hits"
            echo ""
            echo -e "${YELLOW}Fix: Use api.*() for state-mutating requests:${NC}"
            echo -e "  ${BLUE}import { api } from '\$lib/utils/api';${NC}"
            echo -e "  ${BLUE}const res = await api.post('/api/endpoint', body);${NC}"
            echo -e "  ${BLUE}const data = await api.get('/api/endpoint');${NC}"
            echo ""
            echo -e "${YELLOW}For GET-only reads or manual CSRF handling, add ${BLUE}// csrf-ok${YELLOW}:${NC}"
            echo -e "  ${BLUE}const res = await fetch('/api/data'); // csrf-ok${NC}"
            echo ""
            echo -e "${YELLOW}For blob downloads (where you need the raw Response):${NC}"
            echo -e "  ${BLUE}import { getCSRFToken } from '\$lib/utils/api';${NC}"
            echo -e "  ${BLUE}fetch(url, { headers: { 'X-CSRF-Token': getCSRFToken() }, credentials: 'include' }); // csrf-ok${NC}"
            echo ""
            checks_failed=1
        else
            echo -e "${GREEN}✓ No unprotected bare fetch() in client code${NC}"
        fi
    else
        echo -e "${GREEN}✓ CSRF fetch check skipped (server-side files only)${NC}"
    fi
else
    echo -e "${GREEN}✓ CSRF fetch check skipped (no files to check)${NC}"
fi

echo ""

# ============================================================================
# ENGINE BARREL EXPORT CHECK
# ============================================================================
# When engine component files are staged, verify every .svelte file is
# exported from its barrel index.ts. Catches the classic footgun of adding
# a component but forgetting the barrel export — consumers get broken imports.

engine_files=$(git diff --cached --name-only --diff-filter=ACM | grep '^libs/engine/src/lib/ui/components/.*\.svelte$' || true)
if [ -n "$engine_files" ]; then
    echo -e "${YELLOW}🔗 Checking engine barrel exports...${NC}"
    if [ -x "tools/verify-engine-exports.sh" ]; then
        if ! tools/verify-engine-exports.sh --quiet 2>&1; then
            checks_failed=1
        fi
    else
        echo -e "${YELLOW}⚠ tools/verify-engine-exports.sh not found or not executable${NC}"
    fi
    echo ""
else
    echo -e "${GREEN}✓ Engine barrel check skipped (no engine components staged)${NC}"
fi

echo ""

# ============================================================================
# BARE @lucide/svelte IMPORT CHECK (Prism icon gateway)
# ============================================================================
# All icons must go through @autumnsgrove/prism/icons, NOT @lucide/svelte.
# The ONE allowed adapter: libs/prism/src/lib/icons/adapters/lucide.ts
# Suppress with: // prism-ok on the import line (rare — only BeeIcon needs this)

all_staged_for_prism=$(git diff --cached --name-only --diff-filter=ACM | grep '\.\(svelte\|ts\|tsx\|js\|jsx\)$' || true)

if [ -n "$all_staged_for_prism" ]; then
    prism_hits=""
    for f in $all_staged_for_prism; do
        # Skip the one allowed adapter file
        case "$f" in
            *prism/src/lib/icons/adapters/*) continue ;;
        esac
        staged_content=$(git show ":$f" 2>/dev/null || true)
        [ -z "$staged_content" ] && continue
        while IFS=: read -r line_num line_content; do
            [ -z "$line_num" ] && continue
            if echo "$line_content" | grep -q 'prism-ok'; then
                continue
            fi
            prism_hits="${prism_hits}  ${f}:${line_num}: $(echo "$line_content" | sed 's/^[[:space:]]*//')
"
        done < <(echo "$staged_content" | grep -n "from [\"']@lucide/svelte" 2>/dev/null || true)
    done
    prism_hits=$(echo "$prism_hits" | sed '/^$/d')

    if [ -n "$prism_hits" ]; then
        echo -e "${RED}✗ Bare @lucide/svelte import detected${NC}"
        echo -e "${YELLOW}All icons must go through @autumnsgrove/prism/icons:${NC}"
        echo ""
        echo "$prism_hits"
        echo ""
        echo -e "${YELLOW}Fix: Use Prism icon groups instead:${NC}"
        echo -e "  ${BLUE}import { stateIcons, navIcons } from '@autumnsgrove/prism/icons';${NC}"
        echo -e "  ${BLUE}<stateIcons.check class=\"w-5 h-5\" />${NC}"
        echo ""
        echo -e "${YELLOW}To suppress (rare): add ${BLUE}// prism-ok${YELLOW} on the import line${NC}"
        echo ""
        checks_failed=1
    else
        echo -e "${GREEN}✓ No bare @lucide/svelte imports (Prism gateway enforced)${NC}"
    fi
else
    echo -e "${GREEN}✓ Prism icon check skipped (no files to check)${NC}"
fi

echo ""

# ============================================================================
# BARREL IMPORT CASCADE CHECK
# ============================================================================
# Svelte files should NOT import from mega-barrels that pull in dozens of
# components via "export *". Direct file imports prevent CSS cascade bloat
# that can break hydration (see: the Great Barrel Incident of 2026-03).
#
# Dangerous barrels:
#   $lib/ui               — re-exports ALL ui, nature, chrome, stores (~100+ modules)
#   $lib/ui/components/ui  — re-exports 47+ components including Glass → gossamer
#   ../nature" / "/nature" — re-exports 8 sub-modules with 40+ Svelte components
#
# Safe alternatives:
#   import Button from "$lib/ui/components/ui/Button.svelte"
#   import GroveDivider from "$lib/ui/components/nature/GroveDivider.svelte"
#   import { toast } from "$lib/ui/toast"
#
# Suppress with: // barrel-ok on the import line

staged_svelte=$(git diff --cached --name-only --diff-filter=ACM | grep '\.svelte$' || true)

if [ -n "$staged_svelte" ]; then
    barrel_hits=""
    for f in $staged_svelte; do
        # Check staged content (not working tree) for accuracy
        staged_content=$(git show ":$f" 2>/dev/null || true)
        if [ -z "$staged_content" ]; then
            continue
        fi

        # Check each dangerous barrel pattern
        while IFS=: read -r line_num line_content; do
            [ -z "$line_num" ] && continue
            # Skip suppressed lines
            if echo "$line_content" | grep -q 'barrel-ok'; then
                continue
            fi
            barrel_hits="${barrel_hits}  ${f}:${line_num}: $(echo "$line_content" | sed 's/^[[:space:]]*//')
"
        done < <(echo "$staged_content" | grep -n 'from ["\x27]\$lib\/ui["\x27;]' 2>/dev/null || true)

        while IFS=: read -r line_num line_content; do
            [ -z "$line_num" ] && continue
            if echo "$line_content" | grep -q 'barrel-ok'; then
                continue
            fi
            barrel_hits="${barrel_hits}  ${f}:${line_num}: $(echo "$line_content" | sed 's/^[[:space:]]*//')
"
        done < <(echo "$staged_content" | grep -n 'from ["\x27]\$lib\/ui\/components\/ui["\x27;]' 2>/dev/null || true)

        while IFS=: read -r line_num line_content; do
            [ -z "$line_num" ] && continue
            if echo "$line_content" | grep -q 'barrel-ok'; then
                continue
            fi
            barrel_hits="${barrel_hits}  ${f}:${line_num}: $(echo "$line_content" | sed 's/^[[:space:]]*//')
"
        done < <(echo "$staged_content" | grep -n 'from ["\x27][.]*\.\.\?\/nature["\x27;]' 2>/dev/null || true)

        while IFS=: read -r line_num line_content; do
            [ -z "$line_num" ] && continue
            if echo "$line_content" | grep -q 'barrel-ok'; then
                continue
            fi
            barrel_hits="${barrel_hits}  ${f}:${line_num}: $(echo "$line_content" | sed 's/^[[:space:]]*//')
"
        done < <(echo "$staged_content" | grep -n 'from ["\x27]\$lib\/ui\/components\/nature["\x27;]' 2>/dev/null || true)
    done

    # Trim trailing whitespace
    barrel_hits=$(echo "$barrel_hits" | sed '/^$/d')

    if [ -n "$barrel_hits" ]; then
        echo -e "${RED}✗ Barrel import cascade detected in Svelte files${NC}"
        echo -e "${YELLOW}These imports pull in dozens of unused components and CSS,${NC}"
        echo -e "${YELLOW}which can bloat bundles and break hydration:${NC}"
        echo ""
        echo "$barrel_hits"
        echo ""
        echo -e "${YELLOW}Fix: Use direct imports instead:${NC}"
        echo -e "  ${BLUE}import Button from \"\$lib/ui/components/ui/Button.svelte\";${NC}"
        echo -e "  ${BLUE}import GroveDivider from \"\$lib/ui/components/nature/GroveDivider.svelte\";${NC}"
        echo -e "  ${BLUE}import { toast } from \"\$lib/ui/toast\";${NC}"
        echo ""
        echo -e "${YELLOW}To suppress (rare): add ${BLUE}// barrel-ok${YELLOW} on the import line${NC}"
        echo ""
        checks_failed=1
    else
        echo -e "${GREEN}✓ No barrel import cascades in Svelte files${NC}"
    fi
else
    echo -e "${GREEN}✓ Barrel cascade check skipped (no .svelte files staged)${NC}"
fi

echo ""

# ============================================================================
# FINAL RESULTS
# ============================================================================
if [ $checks_failed -eq 1 ]; then
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}Pre-commit checks failed!${NC}"
    echo -e "${RED}Please fix the issues above before committing.${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 1
else
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
    echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    exit 0
fi
